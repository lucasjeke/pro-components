{
  "name": "pro-components",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/archiesong/pro-components.git"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "dev": "turbo dev -F docs",
    "dev:play": "pnpm -F playground dev",
    "lint": "eslint . --fix",
    "ci:publish": "pnpm publish -r --access=public",
    "ci:lint": "eslint",
    "lint:fix": "eslint --fix",
    "ci:changeset": "pnpm changeset",
    "bump": "pnpm changeset version",
    "build:pro": "pnpm -F \"@antdv-next1/**\" build",
    "build:search": "pnpm -F docs run gen:search",
    "build:p": "run-p build:pro build:search",
    "build": "run-s build:p build:site",
    "build:site": "cross-env NODE_OPTIONS=--max-old-space-size=8192 turbo build --filter docs",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "prepare": "simple-git-hooks",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "@ant-design/fast-color": "^3.0.1",
    "@antdv-next/cssinjs": "^1.0.6",
    "@antdv-next/happy-work-theme": "^1.0.0",
    "@antdv-next/icons": "^1.0.8",
    "@antdv-next/unocss": "^1.1.1",
    "@antfu/eslint-config": "^7.7.3",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.30.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/fs-extra": "^11.0.4",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.5.0",
    "@v-c/cascader": "^1.1.1",
    "@v-c/input": "^1.1.0",
    "@v-c/menu": "^1.2.1",
    "@v-c/picker": "^1.1.3",
    "@v-c/portal": "^1.0.8",
    "@v-c/resize-observer": "^1.1.2",
    "@v-c/select": "^1.1.2",
    "@v-c/table": "^1.1.6",
    "@v-c/tabs": "^1.1.1",
    "@v-c/textarea": "^1.1.0",
    "@v-c/tree": "^1.1.1",
    "@v-c/tree-select": "^1.1.1",
    "@v-c/trigger": "^1.0.16",
    "@v-c/upload": "^1.0.0",
    "@v-c/util": "^1.0.19",
    "@v-c/virtual-list": "^1.0.9",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitejs/plugin-vue-jsx": "^5.1.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "antdv-next": "^1.4.0",
    "bumpp": "^10.4.1",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "cross-env": "^10.1.0",
    "csstype": "^3.2.3",
    "dayjs": "^1.11.20",
    "es-toolkit": "^1.45.1",
    "eslint": "^9.39.4",
    "eslint-plugin-format": "^2.0.1",
    "fs-extra": "^11.3.4",
    "jiti": "^2.6.1",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.4.0",
    "mockdate": "^3.0.5",
    "npm-run-all": "^4.1.5",
    "picocolors": "^1.1.1",
    "postcss": "^8.5.8",
    "postcss-selector-parser": "^7.1.1",
    "pretty-format": "^30.3.0",
    "safe-stable-stringify": "^2.5.0",
    "simple-git-hooks": "^2.13.1",
    "swrv": "^1.2.0",
    "tinyglobby": "0.2.15",
    "tsdown": "^0.21.4",
    "tsx": "^4.21.0",
    "turbo": "^2.8.17",
    "typedoc": "^0.28.17",
    "typescript": "~5.9.3",
    "vite": "^8.0.8",
    "vite-plugin-tsx-auto-props": "^0.0.8",
    "vite-plugin-tsx-resolve-types": "^1.0.1",
    "vitest": " ^4.1.0",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4",
    "vue-tsc": "^3.2.6"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged",
    "commit-msg": "node scripts/verify-commit.js"
  },
  "lint-staged": {
    "*.{js,ts,tsx,vue,json}": [
      "pnpm run lint:fix"
    ]
  }
}
