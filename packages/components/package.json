{
  "name": "@antdv-next1/pro-components",
  "type": "module",
  "version": "1.0.35",
  "description": "@antdv-next1/pro-components",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucasjeke/pro-components.git",
    "directory": "packages/components"
  },
  "sideEffects": [
    "./dist/pro-components.esm.js",
    "./dist/pro-components.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dist/*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    },
    "./dist/pro-components.esm.js": "./dist/pro-components.esm.js",
    "./dist/pro-components.js": "./dist/pro-components.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "unpkg": "dist/pro-components.js",
  "jsdelivr": "dist/pro-components.js",
  "types": "./dist/index.d.ts",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "package.json"
  ],
  "scripts": {
    "update:version": "tsx ./scripts/update-version.ts",
    "build": "run-s update:version build:esm build:vite:parallel",
    "build:esm": "tsdown --config-loader unrun",
    "build:vite:parallel": "run-p build:umd build:full-esm",
    "build:full-esm": "vite build --config ./vite.esm.config.ts",
    "build:umd": "vite build",
    "prepublish": "pnpm build"
  },
  "browserslist": [
    "last 2 versions",
    "Firefox ESR",
    "> 1%",
    "ie >= 11"
  ],
  "peerDependencies": {
    "antdv-next": ">=1.3.4",
    "vue": ">=3.5.30"
  },
  "dependencies": {
    "@ant-design/colors": "^7.2.1",
    "@ant-design/fast-color": "^3.0.1",
    "@antdv-next/cssinjs": "^1.0.6",
    "@antdv-next/icons": "^1.1.1",
    "@antdv-next1/pro-card": "workspace:*",
    "@antdv-next1/pro-field": "workspace:*",
    "@antdv-next1/pro-form": "workspace:*",
    "@antdv-next1/pro-layout": "workspace:*",
    "@antdv-next1/pro-listy": "workspace:*",
    "@antdv-next1/pro-provider": "workspace:*",
    "@antdv-next1/pro-table": "workspace:*",
    "@antdv-next1/pro-utils": "workspace:*",
    "@antdv-next1/route-utils": "workspace:*",
    "@dnd-kit/abstract": "^0.4.0",
    "@dnd-kit/collision": "^0.4.0",
    "@dnd-kit/dom": "^0.4.0",
    "@dnd-kit/helpers": "^0.4.0",
    "@dnd-kit/vue": "^0.4.0",
    "dayjs": "^1.11.20",
    "es-toolkit": "^1.45.1",
    "swrv": "^1.2.0"
  },
  "devDependencies": {
    "@v-c/resize-observer": "^1.1.3",
    "@v-c/util": "^1.0.21",
    "@v-c/virtual-list": "^1.0.9"
  },
  "publishConfig": {
    "access": "public"
  },
  "authors": [
    "Chao Song <archiesongqd@gmail.com> (https://github.com/archiesong)"
  ]
}
