{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "paths": {
      "csstype": ["../../node_modules/csstype"],
      "/@tests/*": ["../../tests/*"],
      "@v-c/virtual-list": ["../../node_modules/@v-c/virtual-list"],
      "@v-c/portal": ["../../node_modules/@v-c/portal"],
      "@v-c/menu": ["../../node_modules/@v-c/menu"],
      "@v-c/select": ["../../node_modules/@v-c/select"],
      "@v-c/table": ["../../node_modules/@v-c/table"],
      "@v-c/tabs": ["../../node_modules/@v-c/tabs"],
      "@v-c/trigger": ["../../node_modules/@v-c/trigger"],
      "@v-c/upload": ["../../node_modules/@v-c/upload"]
    },
    "types": ["vite/client", "node"],
    /* Linting */
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "./scripts"]
}
