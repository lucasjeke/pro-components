{
  "name": "@antdv-next1/pro-provider",
  "type": "module",
  "version": "1.0.12",
  "description": "@antdv-next1/pro-provider",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucasjeke/pro-components.git",
    "directory": "packages/provider"
  },
  "sideEffects": [
    "./dist/pro-provider.esm.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dist/*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    },
    "./dist/pro-provider.esm.js": "./dist/pro-provider.esm.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "run-s build:esm build:full-esm",
    "build:esm": "tsdown --config-loader unrun",
    "build:full-esm": "vite build",
    "prepublish": "pnpm build"
  },
  "browserslist": [
    "last 2 versions",
    "Firefox ESR",
    "> 1%",
    "ie >= 11"
  ],
  "peerDependencies": {
    "antdv-next": ">=1.4.0",
    "vue": ">=3.5.30"
  },
  "dependencies": {
    "@ant-design/fast-color": "^3.0.1",
    "@antdv-next/cssinjs": "^1.0.6",
    "@v-c/util": "^1.0.21",
    "dayjs": "^1.11.20"
  },
  "devDependencies": {
    "csstype": "^3.2.3",
    "typescript": "~5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "authors": [
    "Chao Song <archiesongqd@gmail.com> (https://github.com/archiesong)"
  ]
}
