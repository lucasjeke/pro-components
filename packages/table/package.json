{
  "name": "@antdv-next1/pro-table",
  "type": "module",
  "version": "1.0.22",
  "description": "@antdv-next1/pro-table",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/archiesong/pro-components.git",
    "directory": "packages/table"
  },
  "sideEffects": [
    "./dist/pro-table.esm.js",
    "./dist/pro-table.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dist/*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    },
    "./dist/pro-table.esm.js": "./dist/pro-table.esm.js",
    "./dist/pro-table.js": "./dist/pro-table.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "unpkg": "dist/pro-table.js",
  "jsdelivr": "dist/pro-table.js",
  "types": "./dist/index.d.ts",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "run-s build:esm build:vite:parallel",
    "build:esm": "tsdown --config-loader unrun",
    "build:vite:parallel": "run-p build:umd build:full-esm",
    "build:full-esm": "vite build --config ./vite.esm.config.ts",
    "build:umd": "vite build",
    "prepublish": "pnpm build"
  },
  "browserslist": [
    "last 2 versions",
    "Firefox ESR",
    "> 1%",
    "ie >= 11"
  ],
  "peerDependencies": {
    "antdv-next": ">=1.3.4",
    "vue": ">=3.5.30"
  },
  "dependencies": {
    "@antdv-next1/pro-card": "workspace:*",
    "@antdv-next1/pro-field": "workspace:*",
    "@antdv-next1/pro-form": "workspace:*",
    "@antdv-next1/pro-provider": "workspace:*",
    "@antdv-next1/pro-utils": "workspace:*",
    "@dnd-kit/abstract": "^0.4.0",
    "@dnd-kit/collision": "^0.4.0",
    "@dnd-kit/dom": "^0.4.0",
    "@dnd-kit/helpers": "^0.4.0",
    "@dnd-kit/vue": "^0.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "authors": [
    "Chao Song <archiesongqd@gmail.com> (https://github.com/archiesong)"
  ]
}
